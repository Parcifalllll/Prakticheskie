public class MathUtils {
    public static void main(String[] args) {
        // Демонстрация работы методов

        // Вызов метода sum(int a, int b)
        int result1 = sum(5, 7);
        System.out.println("Сумма 5 и 7: " + result1);

        // Вызов перегруженного метода sum(int a, int b, int c)
        int result2 = sum(3, 8, 12);
        System.out.println("Сумма 3, 8 и 12: " + result2);

        // Вызов метода isEven(int number)
        int number1 = 10;
        int number2 = 15;
        System.out.println("Число " + number1 + " чётное: " + isEven(number1));
        System.out.println("Число " + number2 + " чётное: " + isEven(number2));

        // Вызов метода printMessage(String message)
        printMessage("Программа успешно выполнила все математические операции!");
    }

    // 1. Метод суммы двух чисел
    public static int sum(int a, int b) {
        return a + b;
    }

    // 2. Перегруженный метод суммы трёх чисел
    public static int sum(int a, int b, int c) {
        return a + b + c;
    }

    // 3. Метод проверки чётности числа
    public static boolean isEven(int number) {
        return number % 2 == 0;
    }

    // 4. Метод вывода сообщения на экран
    public static void printMessage(String message) {
        System.out.println(message);
    }
}
