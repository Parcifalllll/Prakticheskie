import java.util.*;
import java.util.stream.Collectors;

public class StreamDemo {
    public static void main(String[] args) {
        // 1. Создание ArrayList<Integer> с числами
        List<Integer> numbers = Arrays.asList(1, -2, 3, -4, 5);

        System.out.println("Исходный список чисел:");
        System.out.println(numbers);

        // 2. Обработка с помощью Stream API
        List<Integer> result = numbers.stream()
            // A. Фильтрация только положительных чисел
            .filter(n -> n > 0)
            // B. Возведение в квадрат
            .map(n -> n * n)
            // C. Сбор результата в новый список
            .collect(Collectors.toList());

        // 3. Вывод результирующего списка
        System.out.println("\nРезультирующий список (положительные числа, возведённые в квадрат):");
        System.out.println(result);
    }
}
